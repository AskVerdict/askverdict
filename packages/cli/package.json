{
  "name": "@askverdict/cli",
  "version": "0.1.2",
  "description": "AskVerdict CLI — Run AI debates from your terminal",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "askverdict": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "askverdict",
    "ai",
    "debate",
    "verdict",
    "decision-making",
    "multi-agent",
    "cli"
  ],
  "homepage": "https://askverdict.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/askverdict/askverdict",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "AskVerdict <hello@askverdict.ai>",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@askverdict/types": "workspace:*",
    "@askverdict/sdk": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.2.0"
  }
}
